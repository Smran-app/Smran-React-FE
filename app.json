{
  "expo": {
    "name": "Smran",
    "slug": "smran",
    "scheme": "smran",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon-light.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "usesAppleSignIn": true,
      "bundleIdentifier": "com.smran.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "UIBackgroundModes": ["remote-notification"],
        "NSPhotoLibraryUsageDescription": "Allow Smran to access your photo library to upload profile picture.",
        "NSMicrophoneUsageDescription": "Allow Smran to access your microphone to record voice reminders.",
        "NSSpeechRecognitionUsageDescription": "Allow Smran to use speech recognition to convert your voice into text."
      },
      "appleTeamId": "M7U9K2DATN"
    },
    "notification": {
      "icon": "./assets/notificationIcon/smran_notification_icon.png",
      "color": "#D8B4FE"
    },
    "android": {
      "package": "com.smran.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-apple-authentication",
      [
        "expo-notifications",
        {
          "sounds": ["./assets/alarm.wav", "./assets/alarm2.wav"],
          "enableBackgroundRemoteNotifications": true
        }
      ],
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.95845654362-0l2sf46g9m96chc70ptep3ro6c0qcdaj"
        }
      ],
      "expo-secure-store",
      [
        "expo-av",
        {
          "microphonePermission": "Allow Smran to access your microphone to record voice reminders."
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow Smran to access your microphone to record voice reminders.",
          "speechRecognitionPermission": "Allow Smran to use speech recognition to convert your voice into text."
        }
      ],
      "expo-sqlite"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "85587290-63c2-40b2-920e-4393218874c3"
      }
    }
  }
}
